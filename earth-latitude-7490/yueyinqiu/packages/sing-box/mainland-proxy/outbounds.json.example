{
    "outbounds": [
        {
            "type": "shadowsocks",
            "tag": "server-1",
            "server": "your-server-address-1",
            "server_port": 8388,
            "method": "aes-256-gcm",
            "password": "your-password"
        },
        {
            "type": "shadowsocks",
            "tag": "server-2",
            "server": "your-server-address-2",
            "server_port": 8388,
            "method": "aes-256-gcm",
            "password": "your-password"
        },
        {
            "type": "urltest",
            "tag": "auto",
            "outbounds": [
                "server-1",
                "server-2"
            ],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "1m"
        },
        
        {
            "type": "selector",
            "tag": "proxy",
            "outbounds": [
                "auto",
                "server-1",
                "server-2"
            ],
            "default": "auto"
        },
        {
            "type": "direct",
            "tag": "direct"
        },
        {
            "type": "block",
            "tag": "block"
        }
    ]
}
