// Tips:
// `curl -H "User-Agent: clash-for-windows" --output xxxx https://xxxxxxxxx` to download configuration
// `mihomo2singbox xxxx.yaml -o xxxx.json` to convert it to sing-box format

{
    "outbounds": [
        {
            "type": "shadowsocks",
            "tag": "server-1",
            "server": "your-server-address-1",
            "server_port": 8388,
            "method": "aes-256-gcm",
            "password": "your-password"
        },
        {
            "type": "shadowsocks",
            "tag": "server-2",
            "server": "your-server-address-2",
            "server_port": 8388,
            "method": "aes-256-gcm",
            "password": "your-password"
        }
    ]
}
