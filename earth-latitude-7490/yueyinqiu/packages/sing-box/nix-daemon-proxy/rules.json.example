{
    "route": {
        "rules": [
            {
                "domain_suffix": [
                    "github.com",
                    "githubusercontent.com",
                    "gitlab.com",
                    "web.archive.org"
                ],
                "outbound": "proxy"
            },
            {
                "domain_suffix": [
                    "mirror.nju.edu.cn",
                    "mirrors.tuna.tsinghua.edu.cn",
                    "mirrors.cernet.edu.cn",
                    "mirrors.ustc.edu.cn",
                    "mirrors.cqupt.edu.cn",
                    "mirror.sjtu.edu.cn",
                    "nixos.org",
                    "nuget.org",
                    "packages.microsoft.com",
                    "addons.mozilla.org",
                    "corona.studio"
                ],
                "outbound": "direct"
            }
        ],
        "final": "block"
    }
}