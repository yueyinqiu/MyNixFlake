{
    "inbounds": [
        {
            "type": "mixed",
            "tag": "mixed-in",
            "listen": "127.0.0.1",
            "listen_port": 23569
        }
    ],
    "experimental": {
        "clash_api": {
            "external_controller": "127.0.0.1:62751",
            "external_ui": "ui"
        }
    },
    "outbounds": [
        {
            "type": "direct",
            "tag": "direct"
        },
        {
            "type": "block",
            "tag": "block"
        }
    ],
    "route": {
        "rules": [
            {
                "domain_suffix": [
                    "github.com",
                    "cache.nixos.org"
                ],
                "outbound": "proxy"
            },
            {
                "domain_suffix": [
                    "mirror.nju.edu.cn",
                    "mirrors.tuna.tsinghua.edu.cn",
                    "mirrors.cernet.edu.cn",
                    "mirrors.ustc.edu.cn",
                    "mirrors.cqupt.edu.cn",
                    "mirror.sjtu.edu.cn"
                ],
                "outbound": "direct"
            }
        ],
        "final": "block"
    }
}